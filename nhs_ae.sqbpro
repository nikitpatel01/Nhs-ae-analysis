<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="nhs_ae.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1059"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="ae_data" custom_title="0" dock_id="1" table="4,7:mainae_data"/><dock_state state="000000ff00000000fd0000000100000002000005bb000003c0fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000005bb0000013300ffffff000002690000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="ae_data" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="70"/><column index="2" value="300"/><column index="3" value="113"/><column index="4" value="79"/><column index="5" value="300"/><column index="6" value="97"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes><y_axis name="compliance_pct" line_style="1" point_shape="5" colour="#004586" active="0"/></plot_y_axes><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT trust_name, ROUND(AVG(compliance_pct),1) AS avg_compliance
FROM ae_data
GROUP BY trust_name
ORDER BY avg_compliance ASC
LIMIT 10;


</sql><sql name="SQL 2*">SELECT trust_name, ROUND(AVG(compliance_pct),1) AS avg_compliance
FROM ae_data
WHERE TRIM(trust_name) != '' AND trust_name != '-'
GROUP BY trust_name
HAVING avg_compliance &lt; 95
ORDER BY avg_compliance ASC;</sql><sql name="SQL 3*">SELECT source_file, ROUND(AVG(compliance_pct),1) AS national_avg
FROM ae_data
GROUP BY source_file
ORDER BY source_file;</sql><sql name="SQL 4*">SELECT trust_name,
       ROUND(AVG(compliance_pct),1) AS avg_compliance,
       SUM(total_attendances) AS total_patients
FROM ae_data
GROUP BY trust_name
ORDER BY avg_compliance DESC;</sql><current_tab id="1"/></tab_sql></sqlb_project>
